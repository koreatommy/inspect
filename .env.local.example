# Dashboard → Settings → API Keys에서 동일 프로젝트의 값만 사용하세요.

# 브라우저에 노출됩니다 (NEXT_PUBLIC_ 접두사).
NEXT_PUBLIC_SUPABASE_URL=https://hliykvfxldohkxnizxpy.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy anon JWT를 쓰는 경우:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 — Client Component·브라우저 코드·Git 커밋에 절대 포함하지 마세요.
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard Secret 키(sb_secret_…)를 쓰는 경우:
# SUPABASE_SECRET_KEY=
